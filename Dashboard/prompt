    nodeCanvasObject: (node, ctx) => {
      // Draw glow for ring nodes
      if (node.inRing) {
        ctx.beginPath();
        ctx.arc(node.x, node.y, 8, 0, 2*Math.PI);
        ctx.shadowBlur = 20;
        ctx.shadowColor = '#ef4444';
        ctx.fillStyle = '#ef4444';
        ctx.fill();
        ctx.shadowBlur = 0;
      }
    }
    nodeCanvasObjectMode: (n) => n.inRing ? 'before' : undefined
    linkColor: (l) => {
      if (l.isBackEdge) return '#ef4444';
      if (l.inRing)     return 'rgba(239,68,68,0.5)';
      return 'rgba(82,82,91,0.35)';
    }
    linkWidth: (l) => l.inRing ? 2 : 0.8
    linkDirectionalArrowLength: 3
    linkDirectionalArrowRelPos: 1
