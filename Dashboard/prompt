  if (!inputId) return;
  setLoading(true); setError(null); setResult(null);
  useDashboardUiStore.getState().setPinnedTxnIdForXai(inputId);
  navigate('/investigate/' + inputId, { replace: true });
  try {
    const data = await postExplain(inputId);
    setResult(data);
  } catch(e) {
    setError(e instanceof Error ? e.message : 'Lookup failed');
  } finally {
    setLoading(false);
  }
}

