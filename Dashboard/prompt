export interface GraphNode {
  id:              string;
  isHighRisk:      boolean;
  inRing:          boolean;
  centralityScore: number;
  txnId?:          string;
}
export interface GraphLink {
  source:     string;
  target:     string;
  inRing:     boolean;
  isBackEdge: boolean;
  txnId:      string;
}

export function buildGraphFromTransactions(
  transactions: IngestedTransaction[],
  ringAccountSet: Set<string>,
  backEdgeTxnId:  string | null,
  centralityMap:  Record<string, number>,
): { nodes: GraphNode[]; links: GraphLink[] }

- Cap to last 500 transactions.
- One node per unique account id (source or target).
- One link per transaction (source → target).
- inRing = account id is in ringAccountSet.
- isBackEdge = txn.txn_id === backEdgeTxnId.
- centralityScore from centralityMap[accountId] ?? 0.

`src/lib/pickGraphRing.ts`:

export function pickRingForAlert(
  rings: GraphEngineRing[],
  alert: FraudAlert | null
): GraphEngineRing | null

- If alert?.alert_id matches a ring.ring_id → return that ring.
- Else maximize overlap between alert.cycle_accounts and ring.node_ids.
- Else return rings[0] (lowest priority_rank first).
- Return null if rings is empty.

