# Copy to .env and load before running kafka_scorer.py, or set in your shell.
# Windows + Docker Compose from this repo: Kafka is exposed on the host as 29092.
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# Optional: random load_test txs often score p<0.3 — lower for demo so some hit DB + /explain
# SCORER_THRESHOLD=0.02

# Optional: print one line per message
# SCORER_DEBUG=1
